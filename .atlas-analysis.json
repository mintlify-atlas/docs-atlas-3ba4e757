  "keyFeatures": [
    "Generate images with Flux, Imagen 3, Recraft V4, and more models",
    "CLI with pipe support, JSON output, and watch mode for scripting",
    "Interactive TUI with visual browsing and generation wizards",
    "MCP server for AI agents (Claude, Cursor, Windsurf)",
    "Reusable prompt templates with variables and defaults",
    "Device-based authentication with browser flow"
  ],
  "publicApiSurface": [
    "pixelmuse [prompt] - Generate image",
    "pixelmuse setup - First-time setup wizard",
    "pixelmuse models - List available models",
    "pixelmuse account - View balance and usage",
    "pixelmuse history - Recent generations",
    "pixelmuse open <id> - Open generation in viewer",
    "pixelmuse login - Authenticate",
    "pixelmuse logout - Remove credentials",
    "pixelmuse template <cmd> - Manage prompt templates",
    "pixelmuse ui - Launch interactive TUI",
    "pixelmuse-mcp - MCP server binary"
  ]
